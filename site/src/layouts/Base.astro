---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}
const { title, description = 'Superagente OpenClaw-style em TypeScript ESM' } = Astro.props;
---

<!doctype html>
<html lang="pt-BR" class="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <title>{title} — fzagent</title>
  </head>
  <body class="min-h-screen flex flex-col">
    <header class="border-b border-border">
      <nav class="max-w-5xl mx-auto px-6 py-4 flex items-center gap-6">
        <a href="/" class="text-lg font-bold text-text no-underline">fzagent</a>
        <a href="/steps/00" class="text-sm text-muted hover:text-text">Capitulos</a>
        <a href="/api" class="text-sm text-muted hover:text-text">API</a>
        <a href="/blog" class="text-sm text-muted hover:text-text">Blog</a>
        <span class="ml-auto text-xs text-muted">v0.1.0</span>
      </nav>
    </header>
    <main class="max-w-5xl mx-auto px-6 py-12 flex-1 w-full">
      <slot />
    </main>
    <footer class="border-t border-border mt-12">
      <div class="max-w-5xl mx-auto px-6 py-6 text-sm text-muted flex justify-between">
        <span>fzagent — MIT</span>
        <a href="https://build-your-own-openclaw.kiyo-n-zane.com/">openclaw original</a>
      </div>
    </footer>
  </body>
</html>
