# npm workspaces config
save-exact=false
package-lock=true
audit=false
fund=false

# Performance: usar cache local agressivo
prefer-offline=false

# Python 3.11 via uv para compilar native bindings (better-sqlite3, etc.).
# Sistema tem apenas 3.7.3 que e antigo demais para node-gyp v10.
python=/home/rluft/.local/bin/python3.11
