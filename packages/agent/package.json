{
  "name": "@fzagent/agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Nucleo OpenClaw-style: budget loop, state machine THINK/ACT/OBSERVE/REFLECT, tool registry, sub-agentes, WORA heartbeat",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc -b",
    "clean": "rimraf dist .tsup tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "@fzagent/core": "*",
    "@fzagent/memory": "*",
    "@fzagent/providers": "*",
    "@fzagent/skills": "*",
    "better-sqlite3": "^9.6.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11"
  }
}
