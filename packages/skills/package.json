{
  "name": "@fzagent/skills",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "SkillRegistry com auto-discovery de genaisrc/*.genai.mjs no formato OpenClaw SKILL.md",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc -b",
    "clean": "rimraf dist .tsup tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "@fzagent/core": "*",
    "chokidar": "^4.0.1"
  }
}
