{
  "name": "fzagent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Superagente OpenClaw-style em TypeScript/Node.js ESM com cerebro secundario (SQLite + Qdrant) e multi-provider LLM",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "dev": "npm run dev --workspaces --if-present",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc -b",
    "clean": "rimraf 'packages/*/dist' 'packages/*/.tsup' 'packages/*/tsconfig.tsbuildinfo' tsconfig.tsbuildinfo",
    "ci": "npm run typecheck && npm run lint && npm run format:check && npm test",
    "docs:api": "rimraf docs/api-reference && typedoc",
    "prepare": "husky || true"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@vitest/coverage-v8": "^2.1.5",
    "eslint": "^9.15.0",
    "eslint-config-prettier": "^9.1.0",
    "globals": "^15.12.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.10",
    "prettier": "^3.3.3",
    "rimraf": "^6.0.1",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typedoc": "^0.28.19",
    "typedoc-plugin-markdown": "^4.11.0",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.15.0",
    "vitest": "^2.1.5"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,mdx,yaml,yml,astro}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@google/gemini-cli": "^0.41.2",
    "@google/generative-ai": "^0.24.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/socket.io": "^3.0.1",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "socket.io": "^4.8.3"
  }
}
