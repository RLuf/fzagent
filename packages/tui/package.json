{
  "name": "@fzagent/tui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "REPL Ink fullscreen do fzagent — consome Agent.run() como generator assincrono com renderizacao rica por tipo de AgentEvent.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc -b",
    "clean": "rimraf dist .tsup tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "@fzagent/agent": "*",
    "@fzagent/core": "*",
    "ink": "^5.0.1",
    "ink-text-input": "^6.0.0",
    "picocolors": "^1.1.1",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12"
  }
}
