{
  "name": "@fzagent/memory",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Cerebro secundario: embeddings ONNX BGE-base 768d, Qdrant client, Wiki SQLite indexer com FTS5",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc -b",
    "clean": "rimraf dist .tsup tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "@fzagent/core": "*",
    "@fzagent/providers": "*",
    "@qdrant/js-client-rest": "^1.12.0",
    "better-sqlite3": "^9.6.0",
    "gray-matter": "^4.0.3",
    "onnxruntime-node": "^1.20.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11"
  }
}
