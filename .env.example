# =============================================================================
# fzagent — Variaveis de ambiente (chaves e endpoints)
# =============================================================================
# Copie este arquivo para .env e preencha. NUNCA commite o .env real.
# Configuracoes nao-secretas (ordem de fallback, budgets, intervalos) ficam
# em fzagent.conf. Aqui apenas credenciais e URLs.
# =============================================================================

# ---- Anthropic (Claude) — OAuth-first como o Claude Code -------------------
# Prioridade EXATA (replicada do fazai-ng):
#   CLAUDE_CODE_OAUTH_TOKEN > ANTHROPIC_OAUTH_TOKEN > ANTHROPIC_AUTH_TOKEN > ANTHROPIC_API_KEY
#
# Como obter o OAuth token (recomendado, usa sua assinatura Claude Code Max):
#   $ claude setup-token
# Cole abaixo o token resultante (geralmente comeca com 'sk-ant-oat-...').
CLAUDE_CODE_OAUTH_TOKEN=
# ANTHROPIC_OAUTH_TOKEN=
# ANTHROPIC_AUTH_TOKEN=
# Fallback: API key tradicional do console (https://console.anthropic.com/settings/keys)
ANTHROPIC_API_KEY=

# ---- OpenAI -----------------------------------------------------------------
# https://platform.openai.com/api-keys
OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1

# ---- Google (Gemini via CLI por enquanto) ----------------------------------
# Padrao: usar o `gemini` CLI ja autenticado no seu sistema.
#   $ npx @google/gemini-cli auth login
# Override do binario se necessario:
# GEMINI_CLI_COMMAND=/usr/local/bin/gemini
#
# Opcional: API key direta (uso futuro quando o adapter API estiver pronto).
GOOGLE_API_KEY=

# ---- OpenRouter -------------------------------------------------------------
# https://openrouter.ai/keys
# Prioriza modelos free (sufixo `:free`) — listFreeModels() filtra automaticamente.
OPENROUTER_API_KEY=
# OPENROUTER_REFERER=https://fzagent.local
# OPENROUTER_TITLE=fzagent

# ---- Ollama (papaimach local por padrao) -----------------------------------
# Default = papaimach na rede local (proxy que aceita modelos cloud + locais).
# Para localhost: http://localhost:11434
OLLAMA_BASE_URL=http://192.168.0.101:11434

# ---- Qdrant (vector store) --------------------------------------------------
# Local: http://localhost:6333
# Cloud: https://<cluster>.qdrant.cloud
QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=

# ---- Brave Search (web search provider default) -----------------------------
# https://api.search.brave.com/app/keys
BRAVE_SEARCH_API_KEY=

# ---- Logs / Telemetria ------------------------------------------------------
# trace | debug | info | warn | error | fatal | silent
LOG_LEVEL=info
# pretty (humano) | json (estruturado p/ ingest) | silent (testes)
LOG_FORMAT=pretty
